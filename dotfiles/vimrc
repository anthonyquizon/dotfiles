fu! SendToSocket() range
  let host = 'localhost'
  let port = '8080'
  let tmp = tempname()
  call writefile([expand('%:p')] + [a:firstline.':'.a:lastline] + getline(1, '$'), tmp, 'b')
  call system('nc -c -w0 ' . host . ' ' . port . ' < ' . tmp . ' &')
  call delete(tmp)
endf
