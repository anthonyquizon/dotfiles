cd "$(dirname "$0")"

# bash
ln -svf $PWD/dotfiles/zshrc $HOME/.zprofile
ln -svf $PWD/dotfiles/zshrc $HOME/.zshrc
ln -svf $PWD/dotfiles/zshrc $HOME/.zlogin              # needed for mac

# vim
mkdir -pv $HOME/.vim/undodir
mkdir -pv $HOME/.config/nvim/
ln -svf $PWD/dotfiles/vimrc   $HOME/.vimrc

# vim plugins
rm -rf ~/.vim/pack
git clone --depth 1 https://github.com/preservim/nerdcommenter.git ~/.vim/pack/vendor/start/nerdcommenter
git clone --depth 1 https://github.com/junegunn/fzf.git ~/.vim/pack/plugins/start/fzf
git clone --depth 1 https://github.com/junegunn/fzf.vim.git ~/.vim/pack/plugins/start/fzf.vim
git clone --depth 1 https://github.com/mattn/emmet-vim.git ~/.vim/pack/mattn/start/emmet-vim

# git
ln -sf $PWD/dotfiles/gitconfig $HOME/.gitconfig

# bqn stuff
sudo ln -sf $PWD/bqe /usr/local/bin
sudo ln -sf $PWD/bqf /usr/local/bin
