cd "$(dirname "$0")"

# bash
ln -svf $PWD/dotfiles/zshrc $HOME/.zprofile
ln -svf $PWD/dotfiles/zshrc $HOME/.zshrc
ln -svf $PWD/dotfiles/zshrc $HOME/.zlogin              # needed for mac

# vim
mkdir -pv $HOME/.nvim/undodir
mkdir -pv $HOME/.config/nvim/
ln -svf $PWD/dotfiles/init.vim   $HOME/.config/nvim/init.vim

# neovim plugins (native)
rm -rf ~/.config/nvim/pack
git clone --depth 1 https://github.com/preservim/nerdcommenter.git ~/.config/nvim/pack/vendor/start/nerdcommenter
git clone --depth 1 https://github.com/junegunn/fzf.git ~/.config/nvim/pack/plugins/start/fzf
git clone --depth 1 https://github.com/junegunn/fzf.vim.git ~/.config/nvim/pack/plugins/start/fzf.vim
git clone --depth 1 https://github.com/mattn/emmet-vim.git ~/.config/nvim/pack/mattn/start/emmet-vim

# git
ln -sf $PWD/dotfiles/gitconfig $HOME/.gitconfig

# bqn stuff
mkdir -pv $HOME/.local/bin
ln -sf $PWD/bqe $HOME/.local/bin
ln -sf $PWD/bqf $HOME/.local/bin
